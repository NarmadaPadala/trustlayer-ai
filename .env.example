# OpenAI model configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LangSmith tracing configuration
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=trustlayer-ai-evaluation

# Optional: set only if your LangSmith workspace is outside the default US region
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_WORKSPACE_ID=

# Evaluation tracing behavior
# false logs source length, hash, and preview. true logs the full submitted code.
TRUSTLAYER_TRACE_SOURCE_CODE=false

# For short-lived scripts, this helps traces flush before process exit.
LANGCHAIN_CALLBACKS_BACKGROUND=false
